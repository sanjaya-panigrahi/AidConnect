            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/chats/{{username}}/activity/today",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "chats",
                "{{username}}",
                "activity",
                "today"
              ]
            },
            "description": "Returns today's chat peer summary for one user."
          },
          "response": []
        },
        {
          "name": "Get All Chat Activity Today",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/chats/activity/today",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "chats",
                "activity",
                "today"
              ]
            },
            "description": "Returns today's chat peer summaries for all users."
          },
          "response": []
        }
      ]
    },
