            ],
            "url": {
              "raw": "{{base_url}}/api/chats/conversation?userA={{username}}&userB=bot",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "chats",
                "conversation"
              ],
              "query": [
                {
                  "key": "userA",
                  "value": "{{username}}"
                },
                {
                  "key": "userB",
                  "value": "bot"
                }
              ]
            },
            "description": "Loads conversation history with bot assistant."
          },
          "response": []
        },
