                "{{base_url}}"
              ],
              "path": [
                "api",
                "users",
                "by-username",
                "{{target_username}}"
              ]
            },
            "description": "Fetches one user profile by username."
          },
          "response": []
        },
        {
          "name": "Mark User Online",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/{{username}}/online",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "users",
                "{{username}}",
                "online"
              ]
            },
            "description": "Marks current authenticated user online (path username must match caller)."
          },
          "response": []
        },
        {
          "name": "Mark User Offline",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/{{username}}/offline",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "users",
                "{{username}}",
                "offline"
              ]
