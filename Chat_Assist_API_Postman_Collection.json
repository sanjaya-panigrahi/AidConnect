  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "var token = pm.environment.get('auth_token');",
          "if (!token) {",
          "  console.log('No auth_token set. Login first or rely on stored SESSION cookie.');",
          "}"
        ]
      }
    }
  ],
  "variable": [
