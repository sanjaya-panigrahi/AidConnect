    {
      "name": "Chat",
      "item": [
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senderId\": {{user_id}},\n  \"senderUsername\": \"{{username}}\",\n  \"receiverId\": 2,\n  \"receiverUsername\": \"{{peer_username}}\",\n  \"content\": \"Hello from Postman\",\n  \"messageType\": \"USER\",\n  \"contextUsername\": null\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/chats/messages",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "chats",
                "messages"
              ]
            },
            "description": "Sends one message. Assistant use-cases are also tested through this endpoint."
          },
          "response": []
        },
        {
          "name": "Send Message to Bot",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senderId\": {{user_id}},\n  \"senderUsername\": \"{{username}}\",\n  \"receiverId\": 1001,\n  \"receiverUsername\": \"bot\",\n  \"content\": \"Explain Java streams briefly\",\n  \"messageType\": \"BOT\",\n  \"contextUsername\": null\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/chats/messages",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "chats",
                "messages"
              ]
            },
            "description": "Direct assistant interaction with bot."
          },
          "response": []
        },
        {
          "name": "Send Message to Aid",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senderId\": {{user_id}},\n  \"senderUsername\": \"{{username}}\",\n  \"receiverId\": 1002,\n  \"receiverUsername\": \"aid\",\n  \"content\": \"Book me an appointment tomorrow morning\",\n  \"messageType\": \"BOT\",\n  \"contextUsername\": null\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/chats/messages",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "chats",
                "messages"
              ]
            },
            "description": "Direct assistant interaction with aid appointment assistant."
          },
          "response": []
        },
        {
          "name": "Send Mention-Routed Bot Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senderId\": {{user_id}},\n  \"senderUsername\": \"{{username}}\",\n  \"receiverId\": 2,\n  \"receiverUsername\": \"{{peer_username}}\",\n  \"content\": \"@bot summarize this thread\",\n  \"messageType\": \"USER\",\n  \"contextUsername\": null\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/chats/messages",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "chats",
                "messages"
              ]
            },
            "description": "Tests mention-based rerouting from a normal user chat to bot assistant."
          },
          "response": []
        },
        {
          "name": "Get Conversation",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/chats/conversation?userA={{username}}&userB={{peer_username}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "chats",
                "conversation"
              ],
              "query": [
                {
                  "key": "userA",
                  "value": "{{username}}"
                },
                {
                  "key": "userB",
                  "value": "{{peer_username}}"
                }
              ]
            },
            "description": "Loads conversation history. Requester must be one of the participants."
          },
          "response": []
        },
