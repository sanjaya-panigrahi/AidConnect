            "description": "Marks current authenticated user offline (path username must match caller)."
          },
          "response": []
        },
        {
          "name": "Logout (Primary)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "users",
                "logout"
              ]
            },
            "description": "Primary logout endpoint: records logout event and invalidates server session."
          },
          "response": []
        },
        {
          "name": "Get User Activity Today",
          "request": {
            "method": "GET",
            "header": [
