{
  "info": {
    "name": "Chat Assist API Collection",
    "description": "Postman collection aligned to currently implemented gateway-exposed APIs. Primary public APIs live in user-service and chat-service; assistant processing is exercised through /api/chats/messages.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"username\": \"johndoe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "users",
                "register"
              ]
            },
            "description": "Creates a new user profile and stores password hash in user_credentials."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var jsonData = pm.response.json();",
                  "  if (jsonData.token) pm.environment.set('auth_token', jsonData.token);",
                  "  if (jsonData.userId !== undefined && jsonData.userId !== null) pm.environment.set('user_id', jsonData.userId);",
                  "  if (jsonData.username) pm.environment.set('username', jsonData.username);",
                  "  console.log('Login success. JWT and user context variables updated when present.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"johndoe\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "users",
                "login"
              ]
            },
            "description": "Authenticates user, returns JWT, and creates Redis-backed SESSION cookie."
          },
          "response": []
        },
        {
          "name": "Get Current Session",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/session",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "users",
                "session"
              ]
            },
            "description": "Returns currently authenticated session context. Works with Bearer token or SESSION cookie fallback."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users?excludeUsername={{username}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "users"
              ],
              "query": [
                {
                  "key": "excludeUsername",
                  "value": "{{username}}"
                }
              ]
            },
            "description": "Lists users, optionally excluding one username."
          },
          "response": []
        },
        {
          "name": "List Assistants",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users/assistants",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "users",
                "assistants"
              ]
            },
            "description": "Public endpoint returning assistant summaries (bot, aid)."
          },
          "response": []
        },
        {
          "name": "Get User By Username",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/by-username/{{target_username}}",
