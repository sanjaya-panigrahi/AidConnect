            "description": "Returns today's login/logout summary for one user."
          },
          "response": []
        },
        {
          "name": "Get All Users Activity Today",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/activity/today",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "users",
                "activity",
                "today"
              ]
            },
            "description": "Returns today's login/logout summary for all users."
          },
          "response": []
        }
      ]
