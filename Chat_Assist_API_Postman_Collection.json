              "raw": "{{base_url}}/api/chats/messages/status",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "chats",
                "messages",
                "status"
              ]
            },
            "description": "Updates delivery/seen status for one message."
          },
          "response": []
        },
        {
          "name": "Get My Chat Activity Today",
